{
  "name": "adc-video-bridge",
  "version": "0.1.0",
  "description": "Bridges Alarm.com camera streams to local RTSP via WebRTC for HomeKit Secure Video",
  "author": "Omar Lopez",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Omar-L/adc-video-bridge.git"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "probe": "tsx src/probe.ts",
    "ws-probe": "tsx src/ws-probe.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "node-alarm-dot-com": "^2.1.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "werift": "^0.19.7",
    "ws": "^8.18.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "private": true
}
